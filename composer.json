{
    "name": "mydnic/filament-file-browser",
    "description": "A S3-compatible file browser to list, delete and upload files on any configured disks",
    "keywords": [
        "Mydnic",
        "laravel",
        "filament-file-browser"
    ],
    "homepage": "https://github.com/mydnic/filament-file-browser",
    "support": {
        "issues": "https://github.com/mydnic/filament-file-browser/issues",
        "source": "https://github.com/mydnic/filament-file-browser"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Mydnic",
            "email": "rigoclement@mydnic.be",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "nunomaduro/larastan": "^2.0.1",
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^1.0",
        "phpstan/phpstan-phpunit": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Mydnic\\FilamentFileBrowser\\": "src/",
            "Mydnic\\FilamentFileBrowser\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mydnic\\FilamentFileBrowser\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mydnic\\FilamentFileBrowser\\FilamentFileBrowserServiceProvider"
            ],
            "aliases": {
                "FilamentFileBrowser": "Mydnic\\FilamentFileBrowser\\Facades\\FilamentFileBrowser"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}